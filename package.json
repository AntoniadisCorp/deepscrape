{
  "name": "deepscrape",
  "version": "0.5.2-beta.1",
  "scripts": {
    "ng": "ng",
    "dev": "npm run prbuild && ng serve --configuration=elysia",
    "dev:elysia": "ng serve --configuration=elysia",
    "release:prepare": "npx semantic-release --no-ci --dry-run",
    "release": "npx semantic-release",
    "prebuild": "tsx src/environments/prod_gen.ts",
    "prbuild:dev": "dotenvx run --overload --env BUILD_ENV=development -f .env.dev -- npm run prebuild",
    "prbuild:staging": "dotenvx run --overload --env BUILD_ENV=staging -f .env.staging -- npm run prebuild",
    "prbuild": "dotenvx run --overload --env BUILD_ENV=production -f .env -- npm run prebuild",
    "build:dev": "npm run prbuild:dev && ng build --configuration=development",
    "build:staging": "npm run prbuild:staging && ng build --configuration=staging",
    "build": "npm run prbuild && ng build --configuration=production",
    "build:elysia": "ng build --configuration=elysia",
    "watch": "ng build --watch --configuration development",
    "serve": "npm run build:dev && cd functions && npm run serve",
    "deploy": "npm run build && cd functions && npm run deploy",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "test": "ng test",
    "bun:ssr:deepscrape": "bun --env-file=.env dist/deepscrape/server/server.mjs",
    "node:ssr:deepscrape": "node --env-file=.env dist/deepscrape/server/server.mjs"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "types": {
        "feat": {
          "description": "A new feature",
          "title": "Features"
        },
        "fix": {
          "description": "A bug fix",
          "title": "Bug Fixes"
        },
        "docs": {
          "description": "Documentation only changes",
          "title": "Documentation"
        },
        "style": {
          "description": "Code style changes (formatting, missing semicolons, etc)",
          "title": "Styles"
        },
        "refactor": {
          "description": "Code change that neither fixes a bug nor adds a feature",
          "title": "Refactoring"
        },
        "perf": {
          "description": "A code change that improves performance",
          "title": "Performance"
        },
        "test": {
          "description": "Adding missing tests or correcting existing tests",
          "title": "Tests"
        },
        "build": {
          "description": "Build system or external dependency changes",
          "title": "Builds"
        },
        "ci": {
          "description": "CI/CD configuration and pipeline changes",
          "title": "Continuous Integration"
        },
        "chore": {
          "description": "Maintenance tasks not modifying src or test files",
          "title": "Chores"
        },
        "revert": {
          "description": "Revert a previous commit",
          "title": "Reverts"
        }
      }
    }
  },
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.3.17",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/platform-server": "^20.3.17",
    "@angular/pwa": "^20.3.19",
    "@angular/router": "^20.3.17",
    "@angular/service-worker": "^20.3.17",
    "@angular/ssr": "^20.3.19",
    "@dhutaryan/ngx-mat-timepicker": "^20.2.0",
    "@dotenvx/dotenvx": "^1.54.1",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/node": "^1.2.6",
    "@elysiajs/static": "^1.2.0",
    "@elysiajs/swagger": "^1.2.2",
    "@material-tailwind/html": "^2.3.2",
    "@ngx-loading-bar/core": "^7.0.0",
    "@ngx-loading-bar/http-client": "^7.0.0",
    "@ngx-loading-bar/router": "^7.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@stripe/stripe-js": "^8.0.0",
    "@upstash/ratelimit": "^1.2.0",
    "@upstash/redis": "^1.34.9",
    "chalk": "^5.6.2",
    "chart.js": "^4.5.1",
    "clipboard": "^2.0.11",
    "date-fns": "^4.1.0",
    "elysia": "^1.2.25",
    "emoji-toolkit": "^9.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "firebase": "^11.0.2",
    "http-proxy-middleware": "^3.0.3",
    "idb": "^8.0.2",
    "ioredis": "^5.7.0",
    "libphonenumber-js": "^1.12.29",
    "lucide-angular": "^0.577.0",
    "marked": "^15.0.7",
    "ng2-charts": "^8.0.0",
    "ngx-cookie-service": "^20.1.0",
    "ngx-markdown": "^20.1.0",
    "ngx-stripe": "^20.8.0",
    "node-fetch": "^3.3.2",
    "prismjs": "^1.29.0",
    "rate-limit-redis": "^4.2.0",
    "rxjs": "~7.8.0",
    "stream-buffers": "^3.0.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.19",
    "@angular/cli": "^20.3.19",
    "@angular/compiler-cli": "^20.3.17",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/bun": "^1.2.10",
    "@types/chrome": "^0.0.287",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.14",
    "@types/readable-stream": "^4.0.18",
    "@types/stream-buffers": "^3.0.7",
    "autoprefixer": "^10.4.20",
    "commitizen": "^4.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "firebase-admin": "^13.3.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.1.0",
    "jest": "^29.7.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.4.49",
    "semantic-release": "^24.2.8",
    "tailwindcss": "^3.4.15",
    "tailwindcss-motion": "^1.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
