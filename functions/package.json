{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "lint:fix": "eslint --fix --ext .js,.ts .",
    "test": "node --import tsx --test src/**/*.spec.ts",
    "build:angular": "node cp-angular.js",
    "build": "npm run build:angular && tsc",
    "build:watch": "npm run build:angular && tsc --watch",
    "serve": "npm run build && firebase emulators:start --only \"functions,hosting,pubsub,firestore,auth,storage,eventarc,tasks\" --debug ",
    "shell": "npm run build && dotenvx run --overload --env BUILD_ENV=development -f .env.local -- firebase functions:shell",
    "start": "npm run shell",
    "gen:secret": "node -e \"console.log(require('crypto').randomBytes(48).toString('base64url'))\"",
    "migrate:env:json": "node scripts/migrate-env-to-json.cjs",
    "deploy": "node scripts/deploy-with-json-config.cjs",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22.x",
    "npm": "11.11.x"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@angular/common": "^20.3.17",
    "@dotenvx/dotenvx": "^1.52.0",
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/secret-manager": "^5.6.0",
    "@upstash/ratelimit": "^1.2.0",
    "@upstash/redis": "^1.34.3",
    "chalk": "^5.5.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^7.2.2",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "ip2location-nodejs": "^9.6.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "rate-limit-redis": "^4.2.2",
    "request-ip": "^3.3.0",
    "stripe": "^17.7.0",
    "useragent": "^2.3.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/request-ip": "^0.0.41",
    "@types/stripe": "^8.0.417",
    "@types/useragent": "^2.3.4",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "tsx": "^4.20.6",
    "typescript": "^4.9.0"
  },
  "private": true,
  "trustedDependencies": [
    "protobufjs"
  ]
}
