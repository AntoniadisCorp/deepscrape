rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /{document=**} {
      allow read: if isAuthenticated() && (isAdmin() || resourceMatchesUID());

      allow create: if isAuthenticated() && (isAdmin() || requestMatchesUID());
      allow update: if isAuthenticated() && (isAdmin() || (resourceMatchesUID() && requestMatchesUID()));
      allow delete: if isAuthenticated() && (isAdmin() || resourceMatchesUID());
    }
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId &&
                  (request.auth.token.email_verified || 
                   request.auth.token.phone_number != null ||
                   (request.resource.data.phoneNumber == request.auth.token.phone_number && request.resource.data.phoneVerified == true));
    }
    
    function isAuthenticated() {
    
    	return request.auth != null;
    }
    
    function requestMatchesUID() {
        return request.auth.uid == request.resource.data.uid;
    }

    function resourceMatchesUID() {
        return request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isModerator() {
      return request.auth != null && request.auth.token.role == 'moderator';
    }

    function isManager() {
      return request.auth != null && request.auth.token.role == 'manager';
    }

    function isUser() {
      return request.auth != null && request.auth.token.role == 'user';
    }

    function isGuest() {
      return request.auth != null && request.auth.token.role == 'guest';
    }

    function isTeamLeader(teamId) {
      return request.auth != null && request.auth.token.teams.hasAny([teamId]) && request.auth.token.role == 'team_leader';
    }

    function isTeamMember(teamId) {
      return request.auth != null && request.auth.token.teams.hasAny([teamId]);
    }

    function isOrganizationAdmin(orgId) {
      return request.auth != null && request.auth.token.organization == orgId && request.auth.token.role == 'org_admin';
    }

    function isOrganizationMember(orgId) {
      return request.auth != null && request.auth.token.organization == orgId;
    }
    
    match /login_metrics/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId);
      allow write: if false;
      match /login_history_Info/{historyId} {
        allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.userId);
        allow write: if false;
      }
    }

    match /migration_runs/{runId} {
      allow read, write: if isAdmin();
    }

    match /migration_backups/{runId} {
      allow read, write: if isAdmin();

      match /documents/{docId} {
        allow read, write: if isAdmin();
      }
    }

    match /guests/{guestId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Analytics collections - Admin full access for migration/ops tooling
    match /metrics_daily/{date} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_hourly/{datetime} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_summary/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_range/{rangeId} {
      allow read, write: if isAdmin();
    }
    
  }
}
