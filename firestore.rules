rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At that time, all client
    // requests to your Firestore database will be denied.
    //
    // Make sure to write security rules for your app before that time, or else
    // all client requests to your Firestore database will be denied until you Update
    // your rules
    match /{document=**} {
      // Fallback rule: only admins can access documents not covered by specific rules below.
      // All other access is denied by default.
      allow read, write: if isAdmin();
    }
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId &&
              hasNoSensitiveUserFieldChanges(true);
        allow update: if isAuthenticated() && request.auth.uid == userId &&
              hasNoSensitiveUserFieldChanges(false);

      match /billing/{billingId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if false;
      }

      match /cartpack/{cartpackId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /crawlpack/{crawlpackId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /operations/{operationId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /crawlconfigs/{configId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /crawlresultsconfig/{configId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /apikeys/{keyId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /browser/{profileId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    function isAuthenticated() {
    
    	return request.auth != null;
    }
    
    function hasRole(roleName) {
      return request.auth != null
        && request.auth.token != null
        && ('role' in request.auth.token)
        && request.auth.token.role == roleName;
    }

    function isAdmin() {
        return hasRole('admin');
    }

    function hasNoSensitiveUserFieldChanges(isCreate) {
      // During CREATE: allow phoneNumber/phoneVerified to be set during signup,
      // but block other sensitive fields.
      // During UPDATE: block all sensitive field changes (phone updates must go through backend).
      let alwaysSensitiveFields = [
        'uid', 'email', 'providerId', 'providerParent', 'providerData',
        'role', 'defaultOrgId', 'plan', 'stripeId', 'subscriptionId',
        'status', 'currentUsage', 'balance', 'itemId', 'mfa_enabled',
        'emailVerified', 'profileStatus'
      ];
      let createAllowedFields = ['phoneNumber', 'phoneVerified'];
      let updateSensitiveFields = alwaysSensitiveFields.concat(createAllowedFields);
      
      return isCreate
        ? !request.resource.data.keys().hasAny(alwaysSensitiveFields)
        : !request.resource.data.diff(resource.data).changedKeys().hasAny(updateSensitiveFields);
    }

    function hasOrgRole(orgId, allowedRoles) {
      return isAuthenticated()
        && orgId is string
        && exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId))
        && get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId)).data.role in allowedRoles;
    }

    match /organizations/{orgId} {
      allow read: if isAdmin() || hasOrgRole(orgId, ['owner', 'admin', 'member', 'viewer']);
      allow create, update, delete: if false;
    }

    match /memberships/{membershipId} {
      allow read: if isAdmin()
        || (isAuthenticated() && request.auth.uid == resource.data.userId)
        || hasOrgRole(resource.data.orgId, ['owner', 'admin']);

      allow create, update, delete: if false;
    }

    match /invitations/{inviteId} {
      allow read: if isAdmin() || hasOrgRole(resource.data.orgId, ['owner', 'admin']);
      allow create, update, delete: if false;
    }
    
    match /login_metrics/{docId} {
      allow read: if isAuthenticated() && (request.auth.uid == docId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == docId;
      allow delete: if false;

      match /login_history_Info/{historyId} {
        allow read: if isAuthenticated() && (request.auth.uid == docId || isAdmin());
        allow create, update: if isAuthenticated() && request.auth.uid == docId;
        allow delete: if false;
      }
    }

    match /migration_runs/{runId} {
      allow read, write: if isAdmin();
    }

    match /migration_backups/{runId} {
      allow read, write: if isAdmin();

      match /documents/{docId} {
        allow read, write: if isAdmin();
      }
    }

    match /guests/{guestId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /operation_metrics/{operationId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (('uid' in resource.data) && resource.data.uid == request.auth.uid) ||
        (('userId' in resource.data) && resource.data.userId == request.auth.uid)
      );
      allow write: if false;
    }

    // Analytics collections - Admin full access for migration/ops tooling
    match /metrics_daily/{date} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_hourly/{datetime} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_summary/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /metrics_range/{rangeId} {
      allow read, write: if isAdmin();
    }
    
  }
}
